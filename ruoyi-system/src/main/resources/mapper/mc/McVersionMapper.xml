<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mc.mapper.McVersionMapper">

    <resultMap type="com.ruoyi.mc.domain.McVersion" id="McVersionResult">
        <result property="versionId"    column="version_id"    />
        <result property="versionName"    column="version_name"    />
        <result property="versionCode"    column="version_code"    />
        <result property="packFormat"    column="pack_format"    />
        <result property="description"    column="description"    />
        <result property="status"    column="status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectMcVersionVo">
        select version_id, version_name, version_code, pack_format, description, status, create_by, create_time, update_by, update_time
        from mc_version
    </sql>

    <select id="selectNormalVersionList" resultMap="McVersionResult">
        <include refid="selectMcVersionVo"/>
        where status = '0'
        order by version_id desc
    </select>

    <select id="selectMcVersionByVersionId" parameterType="Long" resultMap="McVersionResult">
        <include refid="selectMcVersionVo"/>
        where version_id = #{versionId}
    </select>

    <select id="selectAllVersions" resultMap="McVersionResult">
        <include refid="selectMcVersionVo"/>
        order by version_id desc
    </select>

    <insert id="batchInsertVersions" parameterType="java.util.List">
        insert into mc_version (version_name, version_code, pack_format, description, status, create_by, create_time)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.versionName}, #{item.versionCode}, #{item.packFormat}, #{item.description}, #{item.status}, #{item.createBy}, sysdate())
        </foreach>
    </insert>

</mapper>
