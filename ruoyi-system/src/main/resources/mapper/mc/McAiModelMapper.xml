<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mc.mapper.McAiModelMapper">

    <resultMap type="McAiModel" id="McAiModelResult">
        <result property="modelId"       column="model_id"       />
        <result property="modelName"     column="model_name"     />
        <result property="modelType"     column="model_type"     />
        <result property="apiUrl"        column="api_url"        />
        <result property="apiKey"        column="api_key"        />
        <result property="modelParams"   column="model_params"   />
        <result property="status"        column="status"         />
        <result property="isActive"      column="is_active"      />
        <result property="createBy"      column="create_by"      />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"      column="update_by"      />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"        column="remark"         />
    </resultMap>

    <sql id="selectMcAiModelVo">
        select model_id, model_name, model_type, api_url, api_key, model_params, status, is_active, create_by, create_time, update_by, update_time, remark from mc_ai_model
    </sql>

    <select id="selectMcAiModelList" parameterType="McAiModel" resultMap="McAiModelResult">
        <include refid="selectMcAiModelVo"/>
        <where>
            <if test="modelName != null  and modelName != ''"> and model_name like concat('%', #{modelName}, '%')</if>
            <if test="modelType != null "> and model_type = #{modelType}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>

    <select id="selectMcAiModelByModelId" parameterType="Long" resultMap="McAiModelResult">
        <include refid="selectMcAiModelVo"/>
        where model_id = #{modelId}
    </select>

    <select id="selectDefaultModelByType" parameterType="Integer" resultMap="McAiModelResult">
        <include refid="selectMcAiModelVo"/>
        where model_type = #{modelType} and status = '0'
        order by model_id asc
        limit 1
    </select>

    <insert id="insertMcAiModel" parameterType="McAiModel" useGeneratedKeys="true" keyProperty="modelId">
        insert into mc_ai_model
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="modelName != null and modelName != ''">model_name,</if>
            <if test="modelType != null">model_type,</if>
            <if test="apiUrl != null and apiUrl != ''">api_url,</if>
            <if test="apiKey != null">api_key,</if>
            <if test="modelParams != null">model_params,</if>
            <if test="status != null">status,</if>
            <if test="isActive != null">is_active,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="modelName != null and modelName != ''">#{modelName},</if>
            <if test="modelType != null">#{modelType},</if>
            <if test="apiUrl != null and apiUrl != ''">#{apiUrl},</if>
            <if test="apiKey != null">#{apiKey},</if>
            <if test="modelParams != null">#{modelParams},</if>
            <if test="status != null">#{status},</if>
            <if test="isActive != null">#{isActive},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateMcAiModel" parameterType="McAiModel">
        update mc_ai_model
        <trim prefix="SET" suffixOverrides=",">
            <if test="modelName != null and modelName != ''">model_name = #{modelName},</if>
            <if test="modelType != null">model_type = #{modelType},</if>
            <if test="apiUrl != null and apiUrl != ''">api_url = #{apiUrl},</if>
            <if test="apiKey != null">api_key = #{apiKey},</if>
            <if test="modelParams != null">model_params = #{modelParams},</if>
            <if test="status != null">status = #{status},</if>
            <if test="isActive != null">is_active = #{isActive},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where model_id = #{modelId}
    </update>

    <delete id="deleteMcAiModelByModelId" parameterType="Long">
        delete from mc_ai_model where model_id = #{modelId}
    </delete>

    <delete id="deleteMcAiModelByModelIds" parameterType="String">
        delete from mc_ai_model where model_id in
        <foreach item="modelId" collection="array" open="(" separator="," close=")">
            #{modelId}
        </foreach>
    </delete>

    <update id="disableOtherModels">
        update mc_ai_model
        set is_active = '0'
        where model_type = #{modelType}
        and model_id != #{excludeModelId}
    </update>

    <select id="getActiveModelByType" resultMap="McAiModelResult">
        <include refid="selectMcAiModelVo"/>
        where model_type = #{modelType}
        and is_active = '1'
        and status = '0'
        limit 1
    </select>
</mapper>
