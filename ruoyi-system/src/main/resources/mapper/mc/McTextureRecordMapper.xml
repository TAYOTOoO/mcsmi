<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mc.mapper.McTextureRecordMapper">

    <resultMap type="McTextureRecord" id="McTextureRecordResult">
        <result property="recordId"         column="record_id"         />
        <result property="taskId"           column="task_id"           />
        <result property="templateId"       column="template_id"       />
        <result property="textureName"      column="texture_name"      />
        <result property="textureNameEn"    column="texture_name_en"   />
        <result property="fileName"         column="file_name"         />
        <result property="filePath"         column="file_path"         />
        <result property="position"         column="position"          />
        <result property="imagePath"        column="image_path"        />
        <result property="status"           column="status"            />
        <result property="createTime"       column="create_time"       />
        <result property="updateTime"       column="update_time"       />
    </resultMap>

    <sql id="selectMcTextureRecordVo">
        select record_id, task_id, template_id, texture_name, texture_name_en,
               file_name, file_path, position, image_path, status, create_time, update_time
        from mc_texture_record
    </sql>

    <select id="selectMcTextureRecordList" parameterType="McTextureRecord" resultMap="McTextureRecordResult">
        <include refid="selectMcTextureRecordVo"/>
        <where>
            <if test="taskId != null"> and task_id = #{taskId}</if>
            <if test="textureName != null and textureName != ''"> and texture_name like concat('%', #{textureName}, '%')</if>
        </where>
        order by position
    </select>

    <select id="selectMcTextureRecordByRecordId" parameterType="Long" resultMap="McTextureRecordResult">
        <include refid="selectMcTextureRecordVo"/>
        where record_id = #{recordId}
    </select>

    <select id="selectMcTextureRecordByTaskId" parameterType="Long" resultMap="McTextureRecordResult">
        <include refid="selectMcTextureRecordVo"/>
        where task_id = #{taskId}
        order by position
    </select>

    <insert id="insertMcTextureRecord" parameterType="McTextureRecord" useGeneratedKeys="true" keyProperty="recordId">
        insert into mc_texture_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskId != null">task_id,</if>
            <if test="templateId != null">template_id,</if>
            <if test="textureName != null">texture_name,</if>
            <if test="textureNameEn != null">texture_name_en,</if>
            <if test="fileName != null">file_name,</if>
            <if test="filePath != null">file_path,</if>
            <if test="position != null">position,</if>
            <if test="imagePath != null">image_path,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="taskId != null">#{taskId},</if>
            <if test="templateId != null">#{templateId},</if>
            <if test="textureName != null">#{textureName},</if>
            <if test="textureNameEn != null">#{textureNameEn},</if>
            <if test="fileName != null">#{fileName},</if>
            <if test="filePath != null">#{filePath},</if>
            <if test="position != null">#{position},</if>
            <if test="imagePath != null">#{imagePath},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateMcTextureRecord" parameterType="McTextureRecord">
        update mc_texture_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="taskId != null">task_id = #{taskId},</if>
            <if test="templateId != null">template_id = #{templateId},</if>
            <if test="textureName != null">texture_name = #{textureName},</if>
            <if test="textureNameEn != null">texture_name_en = #{textureNameEn},</if>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="filePath != null">file_path = #{filePath},</if>
            <if test="position != null">position = #{position},</if>
            <if test="imagePath != null">image_path = #{imagePath},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where record_id = #{recordId}
    </update>

    <delete id="deleteMcTextureRecordByRecordId" parameterType="Long">
        delete from mc_texture_record where record_id = #{recordId}
    </delete>

    <delete id="deleteMcTextureRecordByRecordIds" parameterType="Long">
        delete from mc_texture_record where record_id in
        <foreach item="recordId" collection="array" open="(" separator="," close=")">
            #{recordId}
        </foreach>
    </delete>

</mapper>
