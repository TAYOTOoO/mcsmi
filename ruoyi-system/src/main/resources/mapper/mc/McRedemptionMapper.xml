<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mc.mapper.McRedemptionMapper">

    <resultMap type="com.ruoyi.mc.domain.McRedemption" id="McRedemptionResult">
        <result property="id"    column="id"    />
        <result property="userId"    column="user_id"    />
        <result property="key"    column="key"    />
        <result property="status"    column="status"    />
        <result property="name"    column="name"    />
        <result property="quota"    column="quota"    />
        <result property="createdTime"    column="created_time"    />
        <result property="redeemedTime"    column="redeemed_time"    />
        <result property="usedUserId"    column="used_user_id"    />
        <result property="deletedAt"    column="deleted_at"    />
        <result property="expiredTime"    column="expired_time"    />
    </resultMap>

    <sql id="selectMcRedemptionVo">
        select id, user_id, `key`, status, name, quota, created_time, redeemed_time, used_user_id, deleted_at, expired_time
        from mc_redemptions
    </sql>

    <select id="selectMcRedemptionList" parameterType="com.ruoyi.mc.domain.McRedemption" resultMap="McRedemptionResult">
        <include refid="selectMcRedemptionVo"/>
        <where>
            deleted_at is null
            <if test="userId != null">
                and user_id = #{userId}
            </if>
            <if test="key != null and key != ''">
                and `key` like concat('%', #{key}, '%')
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
            <if test="name != null and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="quota != null">
                and quota = #{quota}
            </if>
            <if test="usedUserId != null">
                and used_user_id = #{usedUserId}
            </if>
        </where>
        order by created_time desc
    </select>

    <select id="selectMcRedemptionById" parameterType="Long" resultMap="McRedemptionResult">
        <include refid="selectMcRedemptionVo"/>
        where id = #{id} and deleted_at is null
    </select>

    <select id="selectMcRedemptionByKey" parameterType="String" resultMap="McRedemptionResult">
        <include refid="selectMcRedemptionVo"/>
        where `key` = #{key} and deleted_at is null
    </select>

    <select id="selectMcRedemptionByIds" parameterType="Long" resultMap="McRedemptionResult">
        <include refid="selectMcRedemptionVo"/>
        where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
        and deleted_at is null
    </select>

    <insert id="insertMcRedemption" parameterType="com.ruoyi.mc.domain.McRedemption" useGeneratedKeys="true" keyProperty="id">
        insert into mc_redemptions
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="key != null and key != ''">`key`,</if>
            <if test="status != null">status,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="quota != null">quota,</if>
            <if test="createdTime != null">created_time,</if>
            <if test="redeemedTime != null">redeemed_time,</if>
            <if test="usedUserId != null">used_user_id,</if>
            <if test="expiredTime != null">expired_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="key != null and key != ''">#{key},</if>
            <if test="status != null">#{status},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="quota != null">#{quota},</if>
            <if test="createdTime != null">#{createdTime},</if>
            <if test="redeemedTime != null">#{redeemedTime},</if>
            <if test="usedUserId != null">#{usedUserId},</if>
            <if test="expiredTime != null">#{expiredTime},</if>
        </trim>
    </insert>

    <insert id="batchInsertRedemptions" parameterType="java.util.List">
        insert into mc_redemptions
        (user_id, `key`, status, name, quota, created_time, redeemed_time, used_user_id, expired_time)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.userId}, #{item.key}, #{item.status}, #{item.name}, #{item.quota},
             #{item.createdTime}, #{item.redeemedTime}, #{item.usedUserId}, #{item.expiredTime})
        </foreach>
    </insert>

    <update id="updateMcRedemption" parameterType="com.ruoyi.mc.domain.McRedemption">
        update mc_redemptions
        <trim prefix="SET" suffixOverrides=",">
            <if test="userId != null">user_id = #{userId},</if>
            <if test="key != null and key != ''">`key` = #{key},</if>
            <if test="status != null">status = #{status},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="quota != null">quota = #{quota},</if>
            <if test="createdTime != null">created_time = #{createdTime},</if>
            <if test="redeemedTime != null">redeemed_time = #{redeemedTime},</if>
            <if test="usedUserId != null">used_user_id = #{usedUserId},</if>
            <if test="expiredTime != null">expired_time = #{expiredTime},</if>
        </trim>
        where id = #{id} and deleted_at is null
    </update>

    <delete id="deleteMcRedemptionById" parameterType="Long">
        update mc_redemptions set deleted_at = now() where id = #{id}
    </delete>

    <delete id="deleteMcRedemptionByIds" parameterType="Long">
        update mc_redemptions set deleted_at = now() where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
