        })
      } else {
        // 超过5MB，降级到服务器上传
        throw new Error('数据量过大，使用服务器存储')
      }
    } catch (storageError) {
      // sessionStorage失败，上传到服务器
      ElMessage.info('数据较大，上传到服务器...')

      const formData = new FormData()
      croppedImages.forEach((blob, index) => {
        formData.append('files', blob, `cropped_${index}.png`)
      })
      formData.append('taskId', taskInfo.value.taskId)

      const uploadRes = await uploadCroppedImages(formData)
      const batchId = uploadRes.data

      ElMessage.success(`裁剪完成！共${croppedImages.length}张材质`)

      // 跳转到编辑页面
      router.push({
        path: '/texture-pack-editor',
        query: { batchId: batchId, taskId: taskInfo.value.taskId }
      })
    }
  } catch (error) {
    if (error !== 'cancel') {
      ElMessage.error(error.message || '生成失败')
    }
  }
}

// 前端裁剪图片（基于辅助线）- 修复：从纯图片裁剪，不包含辅助线
const cropImagesOnClient = async () => {
  return new Promise((resolve, reject) => {
    try {
      if (!canvasImage) {
        reject(new Error('没有图片可裁剪'))
        return
      }

      // 创建临时canvas，只绘制图片（不绘制辅助线）
      const tempCanvas = document.createElement('canvas')
      tempCanvas.width = canvas.value.width
      tempCanvas.height = canvas.value.height
      const tempCtx = tempCanvas.getContext('2d', { willReadFrequently: true })
      tempCtx.imageSmoothingEnabled = false

      // 只绘制图片，不绘制辅助线
      tempCtx.drawImage(canvasImage, 0, 0)

      const imgWidth = tempCanvas.width
      const imgHeight = tempCanvas.height

      // 计算所有矩形区域
      const rectangles = calculateRectangles(horizontalLines.value, verticalLines.value, imgWidth, imgHeight)

      const croppedBlobs = []

      // 裁剪每个区域
      rectangles.forEach(rect => {
        // 创建裁剪canvas
        const cropCanvas = document.createElement('canvas')
        cropCanvas.width = rect.width
        cropCanvas.height = rect.height
        const cropCtx = cropCanvas.getContext('2d')

        // 从纯图片canvas裁剪指定区域（没有辅助线）
        const imageData = tempCtx.getImageData(rect.x, rect.y, rect.width, rect.height)
        cropCtx.putImageData(imageData, 0, 0)

        // 转为Blob（PNG格式，保留透明度）
        cropCanvas.toBlob(blob => {
          croppedBlobs.push(blob)

          // 所有裁剪完成
          if (croppedBlobs.length === rectangles.length) {
            resolve(croppedBlobs)
          }
        }, 'image/png')
      })

      if (rectangles.length === 0) {
        reject(new Error('没有裁剪区域'))
      }
    } catch (error) {
      reject(error)
    }
  })
}

// 计算所有矩形区域
const calculateRectangles = (hLines, vLines, imgWidth, imgHeight) => {
  // 添加边界坐标
  const xCoords = [0, ...vLines, imgWidth].sort((a, b) => a - b)
  const yCoords = [0, ...hLines, imgHeight].sort((a, b) => a - b)

  // 生成所有矩形区域
  const rectangles = []
  for (let j = 0; j < yCoords.length - 1; j++) {
    for (let i = 0; i < xCoords.length - 1; i++) {
      const x = xCoords[i]
      const y = yCoords[j]
      const width = xCoords[i + 1] - x
      const height = yCoords[j + 1] - y

      rectangles.push({ x, y, width, height })
    }
  }

  return rectangles
}

// Blob转Base64
const blobToBase64 = (blob) => {
  return new Promise((resolve, reject) => {
    const reader = new FileReader()
    reader.onloadend = () => resolve(reader.result)
    reader.onerror = reject
    reader.readAsDataURL(blob)
  })
}

// 工具函数
const getImageUrl = (path, overrideTaskId = null) => {
  if (!path) return ''
  if (path.startsWith('http')) return path

  // 获取当前任务ID
  const taskId = overrideTaskId || taskInfo.value?.taskId || route.params.taskId
  if (!taskId) {
    console.error('无法获取taskId')
    return ''
  }

  // 判断资源类型并构建鉴权URL
  if (path.includes('/mc/temp/') || path.includes('\\temp\\')) {
    const fileName = path.split(/[/\\]/).pop()
    return `/api/mc/resource/temp?path=${fileName}&taskId=${taskId}`
  } else if (path.includes('/mc/textures/') || path.includes('\\textures\\')) {
    const fileName = path.split(/[/\\]/).pop()
    return `/api/mc/resource/texture?path=${fileName}&taskId=${taskId}`
  } else if (path.includes('/mc/output/') || path.includes('\\output\\')) {
    const fileName = path.split(/[/\\]/).pop()
    return `/api/mc/resource/download?path=${fileName}&taskId=${taskId}`
  }

  // 兜底：提取文件名，默认从temp目录访问
  const fileName = path.split(/[/\\]/).pop()
  return `/api/mc/resource/temp?path=${fileName}&taskId=${taskId}`
}

