<template>
  <div class="page-wrapper">
    <div class="top-border"></div>
    <div class="content-body">
      <div class="side-border left"></div>
      <main>
        <!-- 页头 -->
        <header class="page-header">
          <div class="mc-box logo">材质工坊</div>
          <nav class="main-nav">
            <ul>
              <li><router-link to="/" class="mc-box">首页</router-link></li>
              <li><router-link to="/generate" class="mc-box">开始生成</router-link></li>
              <li><router-link to="/my-tasks" class="mc-box" :class="{ active: !isVipFactoryMode }">我的任务</router-link></li>
              <li><router-link to="/texture-pack-editor" class="mc-box">材质编辑</router-link></li>
              <li><router-link to="/recharge" class="mc-box">积分充值</router-link></li>
            </ul>
          </nav>

          <div class="user-actions">
            <template v-if="username">
              <span class="mc-box username-display" @click="goToProfile" title="个人中心">{{ username }}</span>
              <button class="mc-box logout-btn" @click="handleLogout">退出</button>
            </template>
            <template v-else>
              <button class="mc-box login-btn" @click="goToLogin">登录</button>
            </template>
          </div>
        </header>

        <!-- 订阅图片分割工厂入口（VipFactory模式 + 未加载图片时显示） -->
        <div v-if="isVipFactoryMode && !canvasImage" class="vip-factory-upload">
          <div class="crop-header vip-header">💎 订阅图片分割工厂</div>
          <div class="upload-area"
            @dragover.prevent="onUploadDragOver"
            @dragleave="onUploadDragLeave"
            @drop.prevent="onUploadDrop"
            :class="{ 'drag-active': uploadDragActive }"
          >
            <div class="upload-content">
              <img src="/assets/images/new-textures/default_tool_diamondpick.png" alt="" class="upload-icon" />
              <p class="upload-title">拖拽图片到此处</p>
              <p class="upload-hint">支持 PNG / JPG 格式</p>
              <button class="mc-box tool-btn" @click="triggerFileSelect">选择文件</button>
              <input type="file" ref="fileInput" accept="image/*" style="display:none" @change="onFileSelected" />
            </div>
          </div>

          <!-- 最近成功任务列表 -->
          <div v-if="recentTasks.length > 0" class="recent-tasks">
            <div class="recent-tasks-header mc-box">最近成功任务（点击加载图片）</div>
            <div class="recent-tasks-list">
              <div
                v-for="task in recentTasks"
                :key="task.taskId"
                class="mc-box recent-task-item"
                @click="loadTaskImage(task)"
              >
                <span class="task-desc">{{ task.styleDescription || '未命名任务' }}</span>
                <span class="task-time">{{ formatTime(task.createTime) }}</span>
              </div>
            </div>
          </div>
        </div>

        <!-- 图片分割工厂 -->
        <div class="crop-container" v-show="!isVipFactoryMode || canvasImage">
          <div class="crop-header" :class="{ 'vip-header': isVipFactoryMode }">
            {{ isVipFactoryMode ? '💎 订阅图片分割工厂' : '图片分割工厂' }}
          </div>

          <!-- 工具栏 -->
          <div class="toolbar mc-box">
            <button
              :class="['tool-btn mc-box', { active: currentTool === 'brush' }]"
              @click="selectTool('brush')"
              title="画笔工具 - 涂抹图片自动清除近似色块"
            >
              <img src="/assets/images/new-textures/default_tool_woodaxe.png" alt="" class="tool-icon" @error="handleIconError">
              画笔
            </button>

            <button
              :class="['tool-btn mc-box', { active: currentTool === 'select' }]"
              @click="selectTool('select')"
              title="框选工具 - 拖拽框选区域，按Delete键删除"
            >
              <img src="/assets/images/new-textures/default_grass.png" alt="" class="tool-icon" @error="handleIconError">
              框选
            </button>

            <button
              class="tool-btn mc-box"
              @click="deleteSelection"
              :disabled="!hasSelection"
              title="删除框选区域 (Delete/Backspace)"
            >
              <img src="/assets/images/new-textures/default_coal_lump.png" alt="" class="tool-icon" @error="handleIconError">
              删除选区
            </button>

            <button
              class="tool-btn mc-box"
              @click="clearSelection"
              :disabled="!hasSelection"
              title="取消框选 (ESC)"
            >
              <img src="/assets/images/new-textures/default_copper_lump.png" alt="" class="tool-icon" @error="handleIconError">
              取消选区
            </button>

            <button
              class="tool-btn mc-box"
              @click="undo"
              :disabled="!canUndo"
              title="撤销上一步操作 (Ctrl+Z)"
            >
              <img src="/assets/images/new-textures/default_stick.png" alt="" class="tool-icon" @error="handleIconError">
              撤销
            </button>

            <button
              class="tool-btn mc-box"
              @click="resetToOriginal"
              :disabled="!canReset"
              title="重置到初始状态"
            >
              <img src="/assets/images/new-textures/default_stick.png" alt="" class="tool-icon rotated" @error="handleIconError">
              重置
            </button>

            <button
              class="tool-btn mc-box"
              @click="preprocessImage"
              title="预处理图片（缩放+边缘处理+实体化）"
            >
              预处理图片
            </button>

            <button
              class="tool-btn mc-box btn-auto"
              @click="autoDetectSprites"
              :title="`自动识别图片中透明分离的素材，调整为${spriteResolution}x${spriteResolution}画布`"
            >
              <img src="/assets/images/new-textures/default_mese_crystal.png" alt="" class="tool-icon" @error="handleIconError">
              自动识别素材
            </button>

            <select
              v-model="spriteResolution"
              @change="saveSpriteResolution"
              class="mc-select"
              title="选择素材分辨率"
            >
              <option :value="16">16×16</option>
              <option :value="32">32×32</option>
              <option :value="64">64×64</option>
              <option :value="128">128×128</option>
              <option :value="256">256×256</option>
              <option :value="512">512×512</option>
              <option :value="1024">1024×1024</option>
            </select>

            <button
              class="tool-btn mc-box"
              @click="exportFullImage"
              title="导出当前编辑后的完整图片"
            >
              导出完整图
            </button>
          </div>

          <!-- VIP: 颜色容差滑块 + 毛边修复 -->
          <div v-if="isFeatureAvailable('color_tolerance') || isFeatureAvailable('fringe_repair')" class="vip-toolbar mc-box">
            <!-- 颜色容差滑块 -->
            <div v-if="isFeatureAvailable('color_tolerance')" class="vip-control">
              <label>💎 画笔容差：{{ colorTolerance }}</label>
              <input type="range" v-model.number="colorTolerance" min="1" max="100" class="mc-slider" />
            </div>

            <!-- 毛边修复滑块 -->
            <div v-if="isFeatureAvailable('fringe_repair')" class="vip-control">
              <label>💎 毛边修复：{{ fringeThreshold }}</label>
              <input type="range" v-model.number="fringeThreshold" min="0" max="100" class="mc-slider" @input="onFringeThresholdChange" />
              <button v-if="fringeThreshold > 0" class="mc-box tool-btn preset-btn" @click="applyFringeRepairEffect">应用</button>
            </div>
          </div>

          <!-- Canvas画布区域 -->
          <div
            class="canvas-wrapper"
            ref="canvasWrapper"
            :class="{ 'cursor-grab': isSpaceDown && !isPanning, 'cursor-grabbing': isPanning }"
            @mousedown="onMouseDown"
            @mousemove="onMouseMove"
            @mouseup="onMouseUp"
            @mouseleave="onMouseLeave"
            @wheel.prevent="onViewportWheel"
            @contextmenu.prevent="onViewportContextMenu"
          >
            <div v-if="loading" class="loading-overlay">
              <p>加载中...</p>
            </div>
            <div class="canvas-pan-layer" :style="canvasPanStyle">
              <canvas
                v-show="!loading"
                ref="canvas"
              ></canvas>
            </div>

            <!-- 坐标tooltip -->
            <div
              v-if="showTooltip"
              class="coord-tooltip"
              :style="{ left: tooltipX + 'px', top: tooltipY + 'px' }"
            >
              {{ tooltipText }}
            </div>
          </div>

          <!-- 预览信息 -->
          <div class="preview-info mc-box">
            <p v-if="currentTool === 'brush'">使用画笔工具清除背景，支持撤销/重置操作</p>
            <p v-else-if="currentTool === 'select'">拖拽鼠标框选区域（可从图片外开始），按Delete删除 | ESC取消</p>
            <p class="hint-text">提示：画笔点击清除 | 框选拖拽删除 | Ctrl+Z撤销 | Ctrl+滚轮缩放 | 空格+拖拽平移 | 右键重置视图</p>
          </div>
        </div>

        <footer class="page-footer">
          © 2026 材质工坊
        </footer>
      </main>
      <div class="side-border right"></div>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, watch, onMounted, nextTick } from 'vue'
import { useRoute, useRouter } from 'vue-router'
import { ElMessage, ElMessageBox } from 'element-plus'
import { getGeneration, listGeneration } from '@/api/generation'
import { logout } from '@/api/auth'
import { uploadCroppedImages } from '@/api/croppedTemp'
import { useVipGate } from '@/composables/useVipGate'
import {
  floodFill as floodFillAlgo,
  getPixelColor,
  setPixelColor,
  isColorSimilar,
  addInnerStroke,
  solidifyEdges,
  addSmartEdgeRepair,
  applyFringeRepair
} from '@/composables/useImageProcessing'

const route = useRoute()
const router = useRouter()
const loading = ref(false)
const taskInfo = ref({})
const username = ref('')

// VIP功能
const { isDiamond, isFeatureAvailable } = useVipGate()

// VipFactory模式判断
const isVipFactoryMode = computed(() => route.name === 'VipFactory')

// Canvas相关
const canvas = ref(null)
const canvasWrapper = ref(null)
const fileInput = ref(null)
let ctx = null
let originalImage = null
let canvasImage = null // 当前编辑后的图片

// 缩放/平移状态（所有用户可用）
const viewZoom = ref(1)
const viewPanX = ref(0)
const viewPanY = ref(0)
const isSpaceDown = ref(false)
const isPanning = ref(false)
let panStartClientX = 0
let panStartClientY = 0
let panStartPanX = 0
let panStartPanY = 0
let displayBaseWidth = 0
let displayBaseHeight = 0

// VIP: 毛边修复状态
const fringeThreshold = ref(0)
let fringePreviewImg = null
let fringePreviewTimer = null

// 撤销/重做历史记录
const historyStack = ref([]) // 历史记录栈
const historyIndex = ref(-1) // 当前历史索引
const MAX_HISTORY = 50 // 最大历史记录数

// 工具状态
const currentTool = ref('brush') // 画笔或框选工具

// Tooltip
const showTooltip = ref(false)
const tooltipX = ref(0)
const tooltipY = ref(0)
const tooltipText = ref('')

// 辅助线闪烁效果
const brushSize = ref(10)
const colorTolerance = ref(parseInt(localStorage.getItem('colorTolerance') || '30'))
watch(colorTolerance, (val) => { localStorage.setItem('colorTolerance', String(val)) })

// 框选工具状态
const isSelecting = ref(false) // 是否正在框选
const selectionStart = ref({ x: 0, y: 0 }) // 框选起点（Canvas坐标）
const selectionEnd = ref({ x: 0, y: 0 }) // 框选终点（Canvas坐标）
const hasSelection = computed(() => {
  const dx = Math.abs(selectionEnd.value.x - selectionStart.value.x)
  const dy = Math.abs(selectionEnd.value.y - selectionStart.value.y)
  return dx > 5 && dy > 5 // 至少5像素才算有效选区
})

// 缩放/平移计算样式（只做平移，缩放通过直接修改canvas CSS尺寸实现以保证清晰度）
const canvasPanStyle = computed(() => ({
  transform: `translate(${viewPanX.value}px, ${viewPanY.value}px)`,
  display: 'inline-block'
}))

// 根据当前zoom更新canvas的CSS尺寸（直接改尺寸而非scale变换，保证image-rendering: pixelated生效）
const updateCanvasDisplaySize = () => {
  if (!canvas.value || !displayBaseWidth) return
  canvas.value.style.width = Math.floor(displayBaseWidth * viewZoom.value) + 'px'
  canvas.value.style.height = Math.floor(displayBaseHeight * viewZoom.value) + 'px'
}

// 将客户端坐标转换为画布内部坐标
// 使用 getBoundingClientRect() 自动处理所有CSS变换（缩放+平移），无需手动计算
const getCanvasCoords = (clientX, clientY) => {
  if (!canvas.value) return { x: 0, y: 0 }
  const rect = canvas.value.getBoundingClientRect()
  return {
    x: Math.round((clientX - rect.left) / rect.width * canvas.value.width),
    y: Math.round((clientY - rect.top) / rect.height * canvas.value.height)
  }
}

// RAF节流重绘
let rafId = null
const scheduleRedraw = () => {
  if (rafId) return
  rafId = requestAnimationFrame(() => {
    redrawCanvas()
    rafId = null
  })
}

// 预处理参数（从localStorage加载，或使用默认值）
const loadPreprocessParams = () => {
  try {
    const saved = localStorage.getItem('preprocessParams')
    if (saved) {
      const parsed = JSON.parse(saved)
      return {
        targetWidth: parsed.targetWidth ?? 600,
        strokeWidth: parsed.strokeWidth ?? 1,
        solidifyIterations: parsed.solidifyIterations ?? 5,
        edgeMode: parsed.edgeMode ?? 'stroke' // 'none' | 'stroke' | 'smart'
      }
    }
  } catch (e) {}
  return {
    targetWidth: 600, strokeWidth: 1, solidifyIterations: 5, edgeMode: 'stroke'
  }
}
const preprocessParams = ref(loadPreprocessParams())

// VIP Factory模式：上传相关
const uploadDragActive = ref(false)
const recentTasks = ref([])

const triggerFileSelect = () => {
  fileInput.value?.click()
}

const onFileSelected = (e) => {
  const file = e.target.files[0]
  if (file) loadImageFromFile(file)
}

const onUploadDragOver = (e) => {
  uploadDragActive.value = true
}

const onUploadDragLeave = () => {
  uploadDragActive.value = false
}

const onUploadDrop = (e) => {
  uploadDragActive.value = false
  const file = e.dataTransfer.files[0]
  if (file && file.type.startsWith('image/')) {
    loadImageFromFile(file)
  } else {
    ElMessage.warning('请拖拽图片文件')
  }
}

const loadImageFromFile = async (file) => {
  loading.value = true
  try {
    const blobUrl = URL.createObjectURL(file)
    await new Promise((resolve, reject) => {
      const img = new Image()
      img.onload = () => {
        originalImage = img
        canvasImage = img
        URL.revokeObjectURL(blobUrl)
        nextTick(() => {
          initCanvas()
          saveHistory()
          loading.value = false
          resolve()
        })
      }
      img.onerror = () => {
        URL.revokeObjectURL(blobUrl)
        ElMessage.error('图片加载失败')
        loading.value = false
        reject()
      }
      img.src = blobUrl
    })
  } catch (e) {
    loading.value = false
  }
}

const loadRecentTasks = async () => {
  try {
    const res = await listGeneration({ taskStatus: 4, pageNum: 1, pageSize: 10 })
    if (res.code === 200 && res.rows) {
      recentTasks.value = res.rows
    }
  } catch (e) {
    console.error('加载最近任务失败:', e)
  }
}

const loadTaskImage = async (task) => {
  taskInfo.value = task
  const imageUrl = task.generatedImageUrl || task.imageUrl
  if (imageUrl) {
    loading.value = true
    try {
      const imageApiUrl = getImageUrl(imageUrl, task.taskId)
      const token = localStorage.getItem('token')
      const response = await fetch(imageApiUrl, {
        headers: { 'Authorization': `Bearer ${token}` }
      })
      if (!response.ok) throw new Error(`图片加载失败: ${response.status}`)
      const blob = await response.blob()
      const blobUrl = URL.createObjectURL(blob)
      await new Promise((resolve, reject) => {
        const img = new Image()
        img.crossOrigin = 'anonymous'
        img.onload = () => {
          originalImage = img
          canvasImage = img
          URL.revokeObjectURL(blobUrl)
          nextTick(() => {
            initCanvas()
            saveHistory()
            resolve()
          })
        }
        img.onerror = () => {
          URL.revokeObjectURL(blobUrl)
          reject()
        }
        img.src = blobUrl
      })
    } catch (e) {
      ElMessage.error('加载任务图片失败')
    } finally {
      loading.value = false
    }
  }
}

const formatTime = (time) => {
  if (!time) return ''
  return time.replace('T', ' ').substring(0, 16)
}

// 自动识别素材的分辨率（从localStorage加载，或使用默认值64）
const loadSpriteResolution = () => {
  try {
    const saved = localStorage.getItem('spriteResolution')
    if (saved) {
      const resolution = parseInt(saved)
      // 验证是否是允许的分辨率
      if ([16, 32, 64, 128, 256, 512, 1024].includes(resolution)) {
        return resolution
      }
    }
  } catch (e) {}
  return 64 // 默认64×64
}
const spriteResolution = ref(loadSpriteResolution())

// 保存分辨率到localStorage
const saveSpriteResolution = () => {
  try {
    localStorage.setItem('spriteResolution', spriteResolution.value.toString())
  } catch (e) {}
}

// 保存预处理参数到localStorage
const savePreprocessParams = () => {
  try {
    localStorage.setItem('preprocessParams', JSON.stringify(preprocessParams.value))
  } catch (e) {}
}

// 计算属性：是否可以撤销
const canUndo = computed(() => historyIndex.value > 0)

// 计算属性：是否可以重置（当前不在初始状态时可以重置）
const canReset = computed(() => historyIndex.value > 0 && historyStack.value.length > 0)

onMounted(async () => {
  username.value = localStorage.getItem('username') || ''

  if (isVipFactoryMode.value) {
    // VipFactory模式：检查VIP身份，加载最近任务
    if (!isDiamond.value) {
      // 非VIP用户，等一下订阅信息可能还没加载完
      await new Promise(resolve => setTimeout(resolve, 1000))
      if (!isDiamond.value) {
        ElMessage.warning('订阅图片分割工厂仅钻石订阅用户可用')
        router.push('/')
        return
      }
    }
    await loadRecentTasks()
  } else {
    // 普通模式：加载任务结果
    const taskId = route.params.taskId
    const hasSavedState = !!sessionStorage.getItem(`editState_${taskId}`)

    await loadTaskResult(hasSavedState)

    if (hasSavedState) {
      await restoreEditState()
    }
  }

  // 添加键盘快捷键监听
  document.addEventListener('keydown', handleKeyDown)
  document.addEventListener('keyup', handleKeyUp)
})

// 键盘快捷键处理
const handleKeyDown = (e) => {
  // 空格键：激活抓手工具（输入框内不处理）
  if (e.code === 'Space' && !e.ctrlKey && !e.altKey) {
    const tag = document.activeElement?.tagName
    if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return
    e.preventDefault()
    isSpaceDown.value = true
    return
  }
  // Ctrl+Z 撤销
  if (e.ctrlKey && e.key === 'z' && !e.shiftKey) {
    e.preventDefault()
    undo()
  }
  // Delete 或 Backspace 删除选区
  if ((e.key === 'Delete' || e.key === 'Backspace') && hasSelection.value) {
    e.preventDefault()
    deleteSelection()
  }
  // ESC 取消选区
  if (e.key === 'Escape' && hasSelection.value) {
    e.preventDefault()
    clearSelection()
    ElMessage.info('已取消选区')
  }
}

const handleKeyUp = (e) => {
  if (e.code === 'Space') {
    isSpaceDown.value = false
    isPanning.value = false
  }
}

// 加载任务结果
const loadTaskResult = async (skipImageLoad = false) => {
  loading.value = true
  try {
    const taskId = route.params.taskId
    const taskRes = await getGeneration(taskId)
    taskInfo.value = taskRes.data

    // 如果有保存的状态，跳过图片加载，让恢复函数处理
    if (!skipImageLoad) {
      // 优先使用 generatedImageUrl，如果为空则使用 imageUrl
      const imageUrl = taskInfo.value.generatedImageUrl || taskInfo.value.imageUrl
      if (imageUrl) {
        await loadImageToCanvas()
      } else {
        ElMessage.warning('暂无生成图片')
      }
    }
  } catch (error) {
    ElMessage.error('加载失败')
  } finally {
    loading.value = false
  }
}

// 加载图片到Canvas
const loadImageToCanvas = async () => {
  try {
    // 优先使用 generatedImageUrl，如果为空则使用 imageUrl
    const imageUrl = taskInfo.value.generatedImageUrl || taskInfo.value.imageUrl
    const imageApiUrl = getImageUrl(imageUrl)

    // 使用 fetch 请求图片，携带 token
    const token = localStorage.getItem('token')
    const response = await fetch(imageApiUrl, {
      headers: {
        'Authorization': `Bearer ${token}`
      }
    })

    if (!response.ok) {
      throw new Error(`图片加载失败: ${response.status}`)
    }

    // 转换为 blob
    const blob = await response.blob()
    // 创建本地 URL
    const blobUrl = URL.createObjectURL(blob)

    // 加载图片
    return new Promise((resolve, reject) => {
      const img = new Image()
      img.crossOrigin = 'anonymous'
      img.onload = () => {
        originalImage = img
        canvasImage = img

        // 释放 blob URL
        URL.revokeObjectURL(blobUrl)

        nextTick(() => {
          initCanvas()
          // 保存初始状态到历史记录
          saveHistory()
          resolve()
        })
      }
      img.onerror = () => {
        URL.revokeObjectURL(blobUrl)
        ElMessage.error('图片加载失败')
        reject()
      }
      img.src = blobUrl
    })
  } catch (error) {
    console.error('加载图片失败:', error)
    ElMessage.error('图片加载失败')
    throw error
  }
}

// 初始化Canvas
const initCanvas = () => {
  if (!canvas.value || !originalImage) return

  // ⚠️ 重要：Canvas内部尺寸必须等于原图尺寸（用于裁剪坐标计算）
  canvas.value.width = originalImage.width
  canvas.value.height = originalImage.height

  // 计算CSS显示尺寸（用于视觉放大，不影响实际尺寸）
  const containerWidth = (canvasWrapper.value?.clientWidth || 800) - 40
  const maxHeight = 1000

  // 默认放大2倍显示以便精确操作
  let displayWidth = originalImage.width * 2
  let displayHeight = originalImage.height * 2

  // 如果放大后超过容器，缩小显示尺寸
  if (displayWidth > containerWidth) {
    const scale = containerWidth / displayWidth
    displayWidth = containerWidth
    displayHeight = displayHeight * scale
  }

  if (displayHeight > maxHeight) {
    const scale = maxHeight / displayHeight
    displayWidth = displayWidth * scale
    displayHeight = maxHeight
  }

  // 通过CSS控制显示尺寸（不影响canvas.width/height）
  canvas.value.style.width = Math.floor(displayWidth) + 'px'
  canvas.value.style.height = Math.floor(displayHeight) + 'px'

  // 保存基础显示尺寸，供坐标转换使用
  displayBaseWidth = Math.floor(displayWidth)
  displayBaseHeight = Math.floor(displayHeight)

  // 加载新图片时重置缩放/平移
  viewZoom.value = 1
  viewPanX.value = 0
  viewPanY.value = 0

  ctx = canvas.value.getContext('2d', {
    willReadFrequently: true,
    imageSmoothingEnabled: false
  })
  redrawCanvas()
}

// 重绘Canvas
const redrawCanvas = () => {
  if (!ctx || !canvasImage) return

  ctx.clearRect(0, 0, canvas.value.width, canvas.value.height)

  // 确保关闭图像平滑以保持清晰
  ctx.imageSmoothingEnabled = false

  // 如果有毛边修复预览图则使用预览图，否则使用原始canvasImage
  const drawSource = (fringePreviewImg && fringeThreshold.value > 0) ? fringePreviewImg : canvasImage
  ctx.drawImage(drawSource, 0, 0)

  // 绘制框选矩形（如果存在）
  if (currentTool.value === 'select' && (isSelecting.value || hasSelection.value)) {
    const x1 = Math.min(selectionStart.value.x, selectionEnd.value.x)
    const y1 = Math.min(selectionStart.value.y, selectionEnd.value.y)
    const x2 = Math.max(selectionStart.value.x, selectionEnd.value.x)
    const y2 = Math.max(selectionStart.value.y, selectionEnd.value.y)
    const width = x2 - x1
    const height = y2 - y1

    if (width > 0 && height > 0) {
      // 绘制半透明填充
      ctx.fillStyle = 'rgba(255, 215, 0, 0.2)'
      ctx.fillRect(x1, y1, width, height)

      // 绘制边框（虚线）
      ctx.strokeStyle = '#FFD700'
      ctx.lineWidth = 2
      ctx.setLineDash([5, 5])
      ctx.strokeRect(x1, y1, width, height)
      ctx.setLineDash([]) // 重置虚线
    }
  }
}

// 鼠标事件处理
const onMouseDown = (e) => {
  if (!canvas.value) return

  // 空格键按住时：开始平移（任意按键）
  if (isSpaceDown.value) {
    isPanning.value = true
    panStartClientX = e.clientX
    panStartClientY = e.clientY
    panStartPanX = viewPanX.value
    panStartPanY = viewPanY.value
    e.preventDefault()
    return
  }

  // 只响应左键的画笔/框选操作
  if (e.button !== 0) return

  const { x: realX, y: realY } = getCanvasCoords(e.clientX, e.clientY)

  if (currentTool.value === 'brush') {
    // 使用画笔工具执行抠图（必须在图片范围内）
    if (realX >= 0 && realX < canvas.value.width && realY >= 0 && realY < canvas.value.height) {
      performFloodFill(realX, realY)
    }
  } else if (currentTool.value === 'select') {
    // 开始框选（允许从任意位置开始）
    isSelecting.value = true
    selectionStart.value = { x: realX, y: realY }
    selectionEnd.value = { x: realX, y: realY }
    scheduleRedraw()
  }
}

const onMouseMove = (e) => {
  if (!canvas.value) return

  // 平移模式
  if (isPanning.value) {
    viewPanX.value = panStartPanX + (e.clientX - panStartClientX)
    viewPanY.value = panStartPanY + (e.clientY - panStartClientY)
    return
  }

  if (currentTool.value === 'select' && isSelecting.value) {
    const { x: realX, y: realY } = getCanvasCoords(e.clientX, e.clientY)
    selectionEnd.value = { x: realX, y: realY }
    scheduleRedraw()
  }
}

const onMouseUp = (e) => {
  // 结束平移
  if (isPanning.value) {
    isPanning.value = false
    return
  }

  if (currentTool.value === 'select' && isSelecting.value) {
    isSelecting.value = false

    // 如果移动距离太小（<5像素），视为点击，取消选区
    if (!hasSelection.value) {
      clearSelection()
    } else {
      scheduleRedraw()
    }
  }
}

const onMouseLeave = (e) => {
  // 不要在 mouseleave 时中断框选
  // 只有在 mouseup 时才结束框选，这样可以避免意外中断
}

// 滚轮缩放（Ctrl + 滚轮）
const onViewportWheel = (e) => {
  if (!e.ctrlKey || !canvas.value || !canvasWrapper.value) return
  const factor = e.deltaY < 0 ? 1.15 : 1 / 1.15
  const newZoom = Math.max(0.1, Math.min(20, viewZoom.value * factor))

  const wrapperRect = canvasWrapper.value.getBoundingClientRect()
  const canvasRect = canvas.value.getBoundingClientRect()

  // 光标相对于wrapper的位置
  const cx = e.clientX - wrapperRect.left
  const cy = e.clientY - wrapperRect.top

  // 当前canvas在wrapper中的位置
  const canvasLeftInWrapper = canvasRect.left - wrapperRect.left
  const canvasTopInWrapper = canvasRect.top - wrapperRect.top

  // 光标到canvas左上角的距离（在当前zoom下的canvas CSS坐标）
  const cursorOnCanvasX = cx - canvasLeftInWrapper
  const cursorOnCanvasY = cy - canvasTopInWrapper

  // 缩放后canvas左上角的新位置（保持光标下的图片点不动）
  const newCanvasLeft = cx - cursorOnCanvasX * newZoom / viewZoom.value
  const newCanvasTop = cy - cursorOnCanvasY * newZoom / viewZoom.value

  // 推算自然居中位置（去掉pan偏移）
  const NL = canvasLeftInWrapper - viewPanX.value
  const NT = canvasTopInWrapper - viewPanY.value

  viewPanX.value = newCanvasLeft - NL
  viewPanY.value = newCanvasTop - NT
  viewZoom.value = newZoom

  // 直接更新canvas CSS尺寸，保证 image-rendering: pixelated 生效，像素完全清晰
  updateCanvasDisplaySize()
}

// 右键重置视图（缩放和平移恢复初始）
const onViewportContextMenu = (e) => {
  viewZoom.value = 1
  viewPanX.value = 0
  viewPanY.value = 0
  updateCanvasDisplaySize()
}

// Flood Fill抠图（画笔功能）
const performFloodFill = async (startX, startY) => {
  if (!ctx) return

  // startX和startY已经是Canvas坐标（=原图坐标），直接使用
  const imageData = ctx.getImageData(0, 0, canvas.value.width, canvas.value.height)
  const targetColor = getPixelColor(imageData, startX, startY)

  // 直接抠除，不判断是否透明（用于微调）
  floodFillAlgo(imageData, startX, startY, targetColor, [0, 0, 0, 0], colorTolerance.value)
  ctx.putImageData(imageData, 0, 0)

  // 更新canvasImage
  canvasImage = await createImageFromCanvas()

  // 保存到历史记录
  saveHistory()

  ElMessage.success('已清除选中区域')
}

// 从Canvas创建Image对象
const createImageFromCanvas = () => {
  return new Promise((resolve) => {
    canvas.value.toBlob((blob) => {
      const img = new Image()
      img.onload = () => resolve(img)
      img.src = URL.createObjectURL(blob)
    })
  })
}

// VIP: 毛边修复 - 非破坏性预览
const onFringeThresholdChange = () => {
  if (fringeThreshold.value === 0) {
    fringePreviewImg = null
    redrawCanvas()
    return
  }
  // 防抖50ms再计算预览，避免滑动时频繁重算
  clearTimeout(fringePreviewTimer)
  fringePreviewTimer = setTimeout(computeFringePreview, 50)
}

const computeFringePreview = () => {
  if (!canvas.value || !canvasImage) return
  // 使用离屏Canvas计算，不影响实际canvasImage
  const offscreen = document.createElement('canvas')
  offscreen.width = canvas.value.width
  offscreen.height = canvas.value.height
  const offCtx = offscreen.getContext('2d', { willReadFrequently: true })
  offCtx.drawImage(canvasImage, 0, 0)
  const imageData = offCtx.getImageData(0, 0, offscreen.width, offscreen.height)
  applyFringeRepair(imageData, fringeThreshold.value)
  offCtx.putImageData(imageData, 0, 0)
  // 生成预览图片
  const img = new Image()
  img.onload = () => {
    fringePreviewImg = img
    redrawCanvas()
  }
  img.src = offscreen.toDataURL()
}

const applyFringeRepairEffect = async () => {
  if (fringeThreshold.value === 0 || !canvas.value) return
  saveHistory()
  // 用离屏Canvas应用修复并更新canvasImage
  const offscreen = document.createElement('canvas')
  offscreen.width = canvas.value.width
  offscreen.height = canvas.value.height
  const offCtx = offscreen.getContext('2d', { willReadFrequently: true })
  offCtx.drawImage(canvasImage, 0, 0)
  const imageData = offCtx.getImageData(0, 0, offscreen.width, offscreen.height)
  applyFringeRepair(imageData, fringeThreshold.value)
  offCtx.putImageData(imageData, 0, 0)
  // 更新canvasImage
  canvasImage = await new Promise(resolve => {
    offscreen.toBlob(blob => {
      const img = new Image()
      img.onload = () => resolve(img)
      img.src = URL.createObjectURL(blob)
    })
  })
  // 重置预览状态并重绘
  fringePreviewImg = null
  fringeThreshold.value = 0
  ctx.drawImage(canvasImage, 0, 0)
  saveHistory()
  ElMessage.success('毛边修复已应用，可使用撤销恢复')
}

// 工具选择
const selectTool = (tool) => {
  currentTool.value = tool
  // 切换工具时清除选区
  if (tool !== 'select') {
    clearSelection()
  }
}

// 清除选区
const clearSelection = () => {
  selectionStart.value = { x: 0, y: 0 }
  selectionEnd.value = { x: 0, y: 0 }
  redrawCanvas()
}

// 删除选区
const deleteSelection = async () => {
  if (!hasSelection.value || !ctx) {
    ElMessage.warning('请先框选要删除的区域')
    return
  }

  try {
    // 计算选区矩形（原始坐标，可能超出图片范围）
    const x1 = Math.min(selectionStart.value.x, selectionEnd.value.x)
    const y1 = Math.min(selectionStart.value.y, selectionEnd.value.y)
    const x2 = Math.max(selectionStart.value.x, selectionEnd.value.x)
    const y2 = Math.max(selectionStart.value.y, selectionEnd.value.y)

    // 裁剪到图片范围内（只删除图片区域）
    const clipX1 = Math.max(0, x1)
    const clipY1 = Math.max(0, y1)
    const clipX2 = Math.min(canvas.value.width, x2)
    const clipY2 = Math.min(canvas.value.height, y2)

    // 检查是否有有效的删除区域
    if (clipX1 >= clipX2 || clipY1 >= clipY2) {
      ElMessage.warning('框选区域不在图片范围内')
      return
    }

    const deleteWidth = clipX2 - clipX1
    const deleteHeight = clipY2 - clipY1

    // 获取当前图像数据
    const imageData = ctx.getImageData(0, 0, canvas.value.width, canvas.value.height)

    // 清除选区内的所有像素（设置为透明）
    for (let y = clipY1; y < clipY2; y++) {
      for (let x = clipX1; x < clipX2; x++) {
        const index = (y * canvas.value.width + x) * 4
        imageData.data[index + 3] = 0 // 设置alpha为0（透明）
      }
    }

    // 应用修改
    ctx.putImageData(imageData, 0, 0)

    // 立即清除选区（在重绘之前）
    selectionStart.value = { x: 0, y: 0 }
    selectionEnd.value = { x: 0, y: 0 }

    // 更新canvasImage
    canvasImage = await createImageFromCanvas()

    // 保存到历史记录
    await saveHistory()

    // 重绘画布（此时选区已清除）
    redrawCanvas()

    ElMessage.success(`已删除选区（${deleteWidth}×${deleteHeight}像素）`)
  } catch (error) {
    ElMessage.error('删除失败：' + (error.message || error))
    console.error('删除选区失败:', error)
    // 错误时也清除选区
    selectionStart.value = { x: 0, y: 0 }
    selectionEnd.value = { x: 0, y: 0 }
    redrawCanvas()
  }
}

// 保存历史记录
const saveHistory = async () => {
  try {
    // 将当前canvas状态转为blob
    const blob = await new Promise(resolve => {
      canvas.value.toBlob(resolve, 'image/png')
    })

    // 清除当前索引之后的所有历史（因为执行了新操作）
    if (historyIndex.value < historyStack.value.length - 1) {
      historyStack.value = historyStack.value.slice(0, historyIndex.value + 1)
    }

    // 添加新的历史记录
    historyStack.value.push(blob)
    historyIndex.value = historyStack.value.length - 1

    // 限制历史记录数量
    if (historyStack.value.length > MAX_HISTORY) {
      historyStack.value.shift()
      historyIndex.value--
    }
  } catch (error) {
    console.error('保存历史记录失败:', error)
  }
}

// 撤销
const undo = async () => {
  if (!canUndo.value) return

  try {
    historyIndex.value--
    const blob = historyStack.value[historyIndex.value]
    await loadImageFromBlob(blob)
    ElMessage.success('已撤销')
  } catch (error) {
    ElMessage.error('撤销失败')
    console.error('撤销失败:', error)
  }
}

// 重置到初始状态
const resetToOriginal = async () => {
  if (!canReset.value) return

  try {
    historyIndex.value = 0
    const blob = historyStack.value[0]
    await loadImageFromBlob(blob)
    ElMessage.success('已重置到初始状态')
  } catch (error) {
    ElMessage.error('重置失败')
    console.error('重置失败:', error)
  }
}

// 保存当前编辑状态到sessionStorage（跳转到材质编辑器前）
const saveEditState = async () => {
  try {
    const taskId = route.params.taskId
    if (!canvas.value || historyStack.value.length === 0) return

    // 保存当前canvas状态为base64
    const currentBlob = await new Promise(resolve => {
      canvas.value.toBlob(resolve, 'image/png')
    })
    const currentBase64 = await blobToBase64(currentBlob)

    // 保存历史记录和索引
    const historyBase64Array = await Promise.all(
      historyStack.value.map(blob => blobToBase64(blob))
    )

    const saveData = {
      taskId,
      currentImage: currentBase64,
      historyStack: historyBase64Array,
      historyIndex: historyIndex.value,
      timestamp: Date.now()
    }

    sessionStorage.setItem(`editState_${taskId}`, JSON.stringify(saveData))
    console.log('编辑状态已保存')
  } catch (error) {
    console.error('保存编辑状态失败:', error)
  }
}

// 恢复编辑状态（从材质编辑器返回时）
const restoreEditState = async () => {
  try {
    const taskId = route.params.taskId
    const savedData = sessionStorage.getItem(`editState_${taskId}`)

    if (!savedData) return

    const data = JSON.parse(savedData)

    // 检查是否是最近保存的（1小时内）
    if (Date.now() - data.timestamp > 3600000) {
      sessionStorage.removeItem(`editState_${taskId}`)
      return
    }

    console.log('检测到保存的编辑状态，正在恢复...')

    // 等待canvas元素渲染
    await nextTick()

    // 恢复历史记录
    historyStack.value = await Promise.all(
      data.historyStack.map(base64 => base64ToBlob(base64))
    )
    historyIndex.value = data.historyIndex

    // 恢复当前图片
    const currentBlob = await base64ToBlob(data.currentImage)
    await loadImageFromBlob(currentBlob)

    // 设置loading为false，确保界面显示
    loading.value = false

    ElMessage.success('已恢复上次编辑状态')

    // 清除保存的状态，避免重复恢复
    sessionStorage.removeItem(`editState_${taskId}`)
  } catch (error) {
    console.error('恢复编辑状态失败:', error)
    // 恢复失败时，重新加载原始图片
    loading.value = false
    await loadImageToCanvas()
  }
}

// Base64转Blob的辅助函数
const base64ToBlob = async (base64) => {
  const response = await fetch(base64)
  return await response.blob()
}

// 从Blob加载图片
const loadImageFromBlob = async (blob) => {
  return new Promise((resolve, reject) => {
    const img = new Image()
    img.onload = () => {
      canvasImage = img
      originalImage = img
      // 重新初始化canvas以正确设置尺寸和显示
      initCanvas()
      resolve()
    }
    img.onerror = reject
    img.src = URL.createObjectURL(blob)
  })
}

