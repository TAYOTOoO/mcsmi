// 自动识别透明分离的素材，并调整为64x64画布
const autoDetectSprites = async () => {
  if (!canvasImage) {
    ElMessage.warning('请先加载图片')
    return
  }

  try {
    // ⚠️ 自动识别前保存当前状态到历史记录，以便撤销
    await saveHistory()

    ElMessage.info('正在识别素材...')

    // 创建临时canvas获取像素数据
    const tempCanvas = document.createElement('canvas')
    tempCanvas.width = canvas.value.width
    tempCanvas.height = canvas.value.height
    const tempCtx = tempCanvas.getContext('2d', { willReadFrequently: true })
    tempCtx.drawImage(canvasImage, 0, 0)

    const imageData = tempCtx.getImageData(0, 0, tempCanvas.width, tempCanvas.height)
    const width = imageData.width
    const height = imageData.height

    // 使用连通域算法检测所有独立的素材
    const visited = new Array(width * height).fill(false)
    const allSprites = []

    for (let y = 0; y < height; y++) {
      for (let x = 0; x < width; x++) {
        const index = y * width + x
        const alphaIndex = index * 4 + 3

        // 跳过透明像素和已访问的像素
        if (visited[index] || imageData.data[alphaIndex] === 0) continue

        // 找到一个新素材，使用BFS收集所有相连的非透明像素
        const sprite = bfsCollectSprite(imageData, x, y, visited, width, height)

        if (sprite.pixels.length > 0) {
          allSprites.push(sprite)
        }
      }
    }

    if (allSprites.length === 0) {
      ElMessage.warning('未检测到素材，请确保素材之间透明分离')
      return
    }

    // 过滤规则：
    // 1. 像素数量至少100个（过滤杂质和噪点）
    // 2. 宽度和高度都至少5像素（过滤单线条噪点）
    const MIN_PIXELS = 100
    const MIN_SIZE = 5

    const validSprites = allSprites.filter(sprite => {
      return sprite.pixels.length >= MIN_PIXELS &&
             sprite.width >= MIN_SIZE &&
             sprite.height >= MIN_SIZE
    })

    const filteredCount = allSprites.length - validSprites.length

    if (validSprites.length === 0) {
      ElMessage.warning(`检测到${allSprites.length}个区域，但都是杂质或噪点（像素数<${MIN_PIXELS}），已全部过滤`)
      return
    }

    if (validSprites.length > 100) {
      ElMessage.warning(`有效素材${validSprites.length}个，数量过多（最多100个）。建议提高图片预处理质量。`)
      return
    }

    // 按原图位置排序：从左到右，从上到下
    // 先按 Y 坐标（从上到下），Y 坐标相近时再按 X 坐标（从左到右）
    validSprites.sort((a, b) => {
      // 如果 Y 坐标差距小于素材高度的一半，认为在同一行
      const yDiff = a.minY - b.minY
      const avgHeight = (a.height + b.height) / 2

      if (Math.abs(yDiff) < avgHeight * 0.5) {
        // 同一行，按 X 坐标排序（从左到右）
        return a.minX - b.minX
      } else {
        // 不同行，按 Y 坐标排序（从上到下）
        return yDiff
      }
    })

    await ElMessageBox.confirm(
      `检测到 ${allSprites.length} 个区域\n` +
      `• 有效素材：${validSprites.length} 个\n` +
      `• 过滤杂质：${filteredCount} 个（像素<${MIN_PIXELS}）\n\n` +
      `将为有效素材生成${spriteResolution.value}×${spriteResolution.value}画布并跳转到材质编辑器\n` +
      `当前编辑已保存到历史记录，可随时撤销`,
      '确认生成',
      {
        confirmButtonText: '确认',
        cancelButtonText: '取消',
        type: 'info'
      }
    )

    const sprites = validSprites

    // 为每个素材创建64x64的画布
    const croppedBlobs = sprites.map(sprite => createSpriteBlob(sprite, imageData))

    // 等待所有blob生成完成
    const blobs = await Promise.all(croppedBlobs)

    // 使用混合存储策略
    const taskId = taskInfo.value.taskId || 'vip-factory-' + Date.now()
    try {
      const imageDataArray = await Promise.all(blobs.map(blob => blobToBase64(blob)))

      const storageData = {
        taskId: taskId,
        images: imageDataArray,
        count: blobs.length
      }

      const jsonStr = JSON.stringify(storageData)
      const sizeInMB = new Blob([jsonStr]).size / (1024 * 1024)

      if (sizeInMB < 5) {
        sessionStorage.setItem('croppedImages', jsonStr)
        ElMessage.success(`识别完成！共${blobs.length}张材质`)

        // ⚠️ 跳转前保存当前编辑状态，以便返回后继续编辑
        if (!isVipFactoryMode.value) {
          await saveEditState()
        }

        router.push({
          path: '/texture-pack-editor',
          query: { source: 'local', taskId: taskId }
        })
      } else {
        throw new Error('数据量过大，使用服务器存储')
      }
    } catch (storageError) {
      ElMessage.info('数据较大，上传到服务器...')

      const formData = new FormData()
      blobs.forEach((blob, index) => {
        formData.append('files', blob, `sprite_${index}.png`)
      })
      formData.append('taskId', taskId)

      const uploadRes = await uploadCroppedImages(formData)
      const batchId = uploadRes.data

      ElMessage.success(`识别完成！共${blobs.length}张材质`)

      // ⚠️ 跳转前保存当前编辑状态，以便返回后继续编辑
      if (!isVipFactoryMode.value) {
        await saveEditState()
      }

      router.push({
        path: '/texture-pack-editor',
        query: { batchId: batchId, taskId: taskId }
      })
    }
  } catch (error) {
    if (error !== 'cancel') {
      ElMessage.error('识别失败：' + (error.message || error))
    }
  }
}

// BFS收集连通的非透明像素（连通域算法）
const bfsCollectSprite = (imageData, startX, startY, visited, width, height) => {
  const pixels = []
  let minX = startX, maxX = startX
  let minY = startY, maxY = startY

  const queue = [[startX, startY]]
  const index = startY * width + startX
  visited[index] = true

  while (queue.length > 0) {
    const [x, y] = queue.shift()
    pixels.push({ x, y })

    // 更新边界
    minX = Math.min(minX, x)
    maxX = Math.max(maxX, x)
    minY = Math.min(minY, y)
    maxY = Math.max(maxY, y)

    // 检查4个方向的相邻像素
    const directions = [[0, 1], [0, -1], [1, 0], [-1, 0]]

    for (const [dx, dy] of directions) {
      const nx = x + dx
      const ny = y + dy

      // 边界检查
      if (nx < 0 || nx >= width || ny < 0 || ny >= height) continue

      const nIndex = ny * width + nx
      if (visited[nIndex]) continue

      const alphaIndex = nIndex * 4 + 3

      // 只收集非透明像素
      if (imageData.data[alphaIndex] > 0) {
        visited[nIndex] = true
        queue.push([nx, ny])
      }
    }
  }

  return {
    pixels,
    minX,
    maxX,
    minY,
    maxY,
    width: maxX - minX + 1,
    height: maxY - minY + 1
  }
}

// 创建指定分辨率画布的素材Blob
const createSpriteBlob = (sprite, imageData) => {
  return new Promise((resolve) => {
    const resolution = spriteResolution.value
    const canvas = document.createElement('canvas')
    canvas.width = resolution
    canvas.height = resolution
    const ctx = canvas.getContext('2d')

    // 背景透明
    ctx.clearRect(0, 0, resolution, resolution)

    // 计算居中偏移
    const offsetX = Math.floor((resolution - sprite.width) / 2)
    const offsetY = Math.floor((resolution - sprite.height) / 2)

    // 绘制每个像素
    sprite.pixels.forEach(({ x, y }) => {
      const sourceIndex = (y * imageData.width + x) * 4
      const r = imageData.data[sourceIndex]
      const g = imageData.data[sourceIndex + 1]
      const b = imageData.data[sourceIndex + 2]
      const a = imageData.data[sourceIndex + 3]

      const targetX = offsetX + (x - sprite.minX)
      const targetY = offsetY + (y - sprite.minY)

      ctx.fillStyle = `rgba(${r},${g},${b},${a / 255})`
      ctx.fillRect(targetX, targetY, 1, 1)
    })

    canvas.toBlob(resolve, 'image/png')
  })
}

// 生成切片并打包
const generateAndPack = async () => {
  if (calculatedCount.value > 100) {
    ElMessage.warning('切片数量过多（最多100张），请减少辅助线')
    return
  }

  try {
