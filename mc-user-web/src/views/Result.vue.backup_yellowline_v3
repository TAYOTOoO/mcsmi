        preprocessParams.value.solidifyIterations = newIter
      } else {
        ElMessage.warning('实体化强度范围应在0-20次之间，使用默认值')
      }

      // 保存参数到localStorage
      savePreprocessParams()
    }

    // 步骤2：确认执行
    let edgeDesc = ''
    if (preprocessParams.value.edgeMode === 'smart') {
      edgeDesc = '2. 💎 智能边缘修复（用内层像素颜色覆盖半透明边缘）\n'
    } else if (preprocessParams.value.edgeMode === 'stroke' && preprocessParams.value.strokeWidth > 0) {
      edgeDesc = `2. 添加 ${preprocessParams.value.strokeWidth}px 黑色内描边\n`
    } else {
      edgeDesc = '2. 不处理边缘\n'
    }

    await ElMessageBox.confirm(
      '预处理将执行以下操作：\n' +
      `1. 缩放图片宽度到 ${preprocessParams.value.targetWidth}px（保持比例，最近邻插值）\n` +
      edgeDesc +
      `3. 实体化半透明边缘（强度：${preprocessParams.value.solidifyIterations}次）\n` +
      '\n此操作会保存到历史记录，可以撤销。是否继续？',
      '确认预处理',
      {
        confirmButtonText: '开始处理',
        cancelButtonText: '取消',
        type: 'warning'
      }
    )

    // ⚠️ 预处理前保存当前状态到历史记录，以便撤销
    await saveHistory()

    // 创建临时canvas进行预处理
    const tempCanvas = document.createElement('canvas')
    const tempCtx = tempCanvas.getContext('2d', { willReadFrequently: true })

    // 1. 缩放到目标宽度（最近邻插值）
    const targetWidth = preprocessParams.value.targetWidth
    const sourceImg = canvasImage
    const scale = targetWidth / sourceImg.width
    const targetHeight = Math.floor(sourceImg.height * scale)

    tempCanvas.width = targetWidth
    tempCanvas.height = targetHeight

    // 禁用平滑以实现最近邻插值（硬边缘）
    tempCtx.imageSmoothingEnabled = false
    tempCtx.drawImage(sourceImg, 0, 0, targetWidth, targetHeight)

    // 2. 边缘处理
    if (preprocessParams.value.edgeMode === 'smart') {
      // VIP: 智能边缘修复
      const imageData = tempCtx.getImageData(0, 0, targetWidth, targetHeight)
      addSmartEdgeRepair(imageData, 5)
      tempCtx.putImageData(imageData, 0, 0)
    } else if (preprocessParams.value.edgeMode === 'stroke' && preprocessParams.value.strokeWidth > 0) {
      // 黑色内描边
      const imageData = tempCtx.getImageData(0, 0, targetWidth, targetHeight)
      addInnerStroke(imageData, preprocessParams.value.strokeWidth)
      tempCtx.putImageData(imageData, 0, 0)
    }

    // 3. 实体化半透明黑边（如果启用）
    if (preprocessParams.value.solidifyIterations > 0) {
      const solidifiedImageData = solidifyEdges(
        tempCtx.getImageData(0, 0, targetWidth, targetHeight),
        preprocessParams.value.solidifyIterations
      )
      tempCtx.putImageData(solidifiedImageData, 0, 0)
    }

    // 更新原图和Canvas图
    originalImage = await createImageFromTempCanvas(tempCanvas)
    canvasImage = originalImage

    // 重新初始化Canvas显示
    initCanvas()

    // ⚠️ 预处理后保存新状态到历史记录
    await saveHistory()

    let edgeMsg = ''
    if (preprocessParams.value.edgeMode === 'smart') {
      edgeMsg = '智能修复边缘，'
    } else if (preprocessParams.value.edgeMode === 'stroke' && preprocessParams.value.strokeWidth > 0) {
      edgeMsg = `描边${preprocessParams.value.strokeWidth}px，`
    } else {
      edgeMsg = '无描边，'
    }
    ElMessage.success(
      `预处理完成！图片已缩放到${targetWidth}px宽度，` +
      edgeMsg +
      `实体化${preprocessParams.value.solidifyIterations}次`
    )
  } catch (error) {
    if (error !== 'cancel' && error !== 'close') {
      ElMessage.error('预处理失败：' + (error.message || error))
    }
  }
}

